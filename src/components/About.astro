---
const stats = [
  { value: "18 mo", label: "Leading Vubo Engineering" },
  { value: "3", label: "SaaS Products Shipped" },
  { value: "45+", label: "AI Models Integrated" },
  { value: "80+", label: "Backend Tests in Production" },
];
---

<section id="about" class="relative py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-2 gap-16 items-start">
      <!-- Left column -->
      <div>
        <span class="section-label">About</span>
        <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-6">
          I solve problems with software,<br/>
          <span class="text-text-secondary">then ship it to real users</span>
        </h2>
        <div class="space-y-4 text-text-secondary leading-relaxed">
          <p>
            At <a href="https://vubo.ai" target="_blank" rel="noopener" class="text-accent-light hover:underline">Vubo</a>,
            creators wanted AI-generated videos but had to jump between tools for scripting, generating,
            and rendering. I built the platform that replaced all of that. 45+ AI model integrations,
            server-side rendering on AWS Lambda, async job queues
            handling thousands of renders. Started as the first engineer, grew the codebase over 18 months
            with a team of 12.
          </p>
          <p>
            I pick the architecture, set up CI/CD, write tests, handle infra, and push to prod.
            <strong class="text-text-primary">Social Claw</strong> went from nothing to a full SaaS
            (billing, DM automation, multi-platform scheduling, 80+ backend tests).
            <strong class="text-text-primary">Internet Mindmap</strong> runs a RAG-powered knowledge graph
            with Chrome extension on Cloudflare's free tier.
          </p>
          <p>
            Recently migrated Vubo to Next.js 16 with Partial Pre-Rendering and set up a Turborepo
            monorepo while keeping up with new AI model integrations.
          </p>
        </div>
      </div>

      <!-- Right column -->
      <div class="space-y-8">
        <!-- Stats -->
        <div class="grid grid-cols-2 gap-4">
          {stats.map(stat => (
            <div class="p-4 rounded-xl border border-border-subtle bg-bg-secondary/30 hover:border-accent/30 transition-colors duration-300">
              <div class="text-2xl font-bold text-text-primary font-mono mb-1 stat-value" data-target={stat.value}>{stat.value}</div>
              <div class="text-xs text-text-muted">{stat.label}</div>
            </div>
          ))}
        </div>

        <!-- What I bring card -->
        <div class="p-6 rounded-xl border border-border-subtle bg-bg-secondary/30">
          <h3 class="text-sm font-mono text-text-muted mb-4 uppercase tracking-wider">What I Bring</h3>
          <div class="space-y-3">
            <div class="flex items-start justify-between gap-3 text-sm border-b border-border-subtle/40 pb-3">
              <span class="text-text-muted shrink-0">Core Stack</span>
              <span class="text-text-secondary text-right">TypeScript, React, Next.js</span>
            </div>
            <div class="flex items-start justify-between gap-3 text-sm border-b border-border-subtle/40 pb-3">
              <span class="text-text-muted shrink-0">Backend</span>
              <span class="text-text-secondary text-right">Node.js, Hono, Convex, Python</span>
            </div>
            <div class="flex items-start justify-between gap-3 text-sm border-b border-border-subtle/40 pb-3">
              <span class="text-text-muted shrink-0">Infra & DevOps</span>
              <span class="text-text-secondary text-right">AWS, Cloudflare, Vercel, Docker</span>
            </div>
            <div class="flex items-start justify-between gap-3 text-sm border-b border-border-subtle/40 pb-3">
              <span class="text-text-muted shrink-0">Superpower</span>
              <span class="text-text-secondary text-right">Prod-quality systems, shipped fast</span>
            </div>
            <div class="flex items-start justify-between gap-3 text-sm">
              <span class="text-text-muted shrink-0">GitHub</span>
              <a href="https://github.com/Srijan-t0d0" target="_blank" rel="noopener" class="text-accent-light hover:underline text-right">@Srijan-t0d0</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Count-up animation for stat numbers
  function animateCount(el: HTMLElement) {
    const raw = el.dataset.target ?? '';
    const suffix = raw.replace(/[\d.]/g, '');        // e.g. " mo", "+", ""
    const num = parseFloat(raw.replace(/[^\d.]/g, ''));
    if (isNaN(num)) return;

    const isDecimal = raw.includes('.');
    const duration = 900;
    const start = performance.now();

    const tick = (now: number) => {
      const t = Math.min((now - start) / duration, 1);
      const eased = 1 - Math.pow(1 - t, 3);          // cubic ease-out
      const current = eased * num;
      el.textContent = (isDecimal ? current.toFixed(1) : Math.round(current).toString()) + suffix;
      if (t < 1) requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  }

  const statEls = document.querySelectorAll<HTMLElement>('.stat-value');
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          animateCount(e.target as HTMLElement);
          observer.unobserve(e.target);
        }
      });
    },
    { threshold: 0.6 }
  );
  statEls.forEach((el) => observer.observe(el));
</script>
