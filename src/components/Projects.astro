---

<section id="projects" class="relative py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <span class="section-label">Projects</span>
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">
      Featured work
    </h2>

    <!-- Featured projects -->
    <div class="space-y-8 mb-20">
      {featured.map((project, i) => (
        <article class="project-featured spotlight-card group relative p-6 sm:p-8 lg:p-10 rounded-2xl border border-border-subtle/40 bg-bg-secondary/20">

          {/* Watermark index number */}
          <span
            class="project-index absolute top-4 right-5 sm:top-6 sm:right-8 text-[72px] sm:text-[96px] font-bold text-text-primary/[0.025] font-mono select-none pointer-events-none"
            aria-hidden="true"
          >
            {String(i + 1).padStart(2, '0')}
          </span>

          {/* ── Header: Logo + Title + Role + Live ── */}
          <div class="flex items-start justify-between gap-4 mb-7">
            <div class="flex items-start gap-3.5">
              <div class="w-12 h-12 rounded-xl bg-bg-primary border border-border-subtle/50 flex items-center justify-center shrink-0 shadow-lg shadow-black/25">
                {project.favicon ? (
                  <img
                    src={project.favicon}
                    alt={`${project.title} icon`}
                    class="w-7 h-7 rounded-md object-contain"
                    loading="lazy"
                  />
                ) : (
                  <svg class="w-6 h-6 text-accent-light/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" />
                  </svg>
                )}
              </div>
              <div class="min-w-0">
                <h3 class="text-2xl sm:text-3xl font-bold text-text-primary tracking-[-0.025em] leading-tight">
                  {project.title}
                </h3>
                <p class="text-[11px] sm:text-xs font-mono text-accent-light/60 mt-1.5 tracking-wide">
                  {project.role}
                </p>
              </div>
            </div>

            {project.live && (
              <a
                href={project.live}
                target="_blank"
                rel="noopener noreferrer"
                class="group/live inline-flex items-center gap-2 shrink-0 py-1.5 px-3 rounded-lg hover:bg-accent/5 transition-all duration-300"
              >
                <span class="relative flex h-2 w-2">
                  <span class="absolute inline-flex h-full w-full rounded-full bg-green opacity-50 animate-pulse-dot"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-green"></span>
                </span>
                <span class="font-mono text-[11px] text-text-muted group-hover/live:text-accent-light transition-colors tracking-wider">Live</span>
                <svg class="w-3 h-3 text-text-muted/0 group-hover/live:text-text-muted transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            )}
          </div>

          {/* ── Metrics row ── */}
          <div class="grid grid-cols-3 gap-3 sm:gap-4 mb-7">
            {project.metrics.map((m, mi) => (
              <div
                class="project-metric text-center py-3.5 px-3 rounded-xl"
                style={`animation-delay: ${mi * 0.08}s`}
              >
                <div class="text-lg sm:text-xl font-bold font-mono text-text-primary leading-none tracking-tight">
                  {m.value}
                </div>
                <div class="text-[9px] sm:text-[10px] font-mono text-text-muted uppercase tracking-[0.1em] mt-2">
                  {m.label}
                </div>
              </div>
            ))}
          </div>

          {/* ── Divider ── */}
          <div class="project-divider mb-7"></div>

          {/* ── Narrative: Challenge → Build → Impact ── */}
          <div class="space-y-5 mb-8 max-w-3xl">
            <div class="narrative-section narrative-challenge pl-4 border-l-2 border-warm/25 transition-all duration-500">
              <span class="text-[10px] font-mono uppercase tracking-[0.15em] text-warm/50 mb-1.5 block">
                The Challenge
              </span>
              <p class="text-[13px] text-text-secondary leading-relaxed">
                {project.problem}
              </p>
            </div>

            <div class="narrative-section narrative-build pl-4 border-l-2 border-border-subtle transition-all duration-500">
              <span class="text-[10px] font-mono uppercase tracking-[0.15em] text-text-muted/60 mb-1.5 block">
                What I Built
              </span>
              <p class="text-[13px] text-text-secondary leading-relaxed">
                {project.solution}
              </p>
            </div>

            <div class="narrative-section narrative-impact pl-4 border-l-2 border-accent/25 transition-all duration-500">
              <span class="text-[10px] font-mono uppercase tracking-[0.15em] text-accent-light/50 mb-1.5 block">
                The Impact
              </span>
              <p class="text-[13px] text-text-secondary leading-relaxed">
                {project.impact}
              </p>
            </div>
          </div>

          {/* ── Tech stack ── */}
          <div class="pt-6 border-t border-border-subtle/25">
            <div class="flex flex-wrap gap-1.5">
              {project.tech.map(t => (
                <span class="tech-badge">{t}</span>
              ))}
            </div>
          </div>

        </article>
      ))}
    </div>

    <!-- Other noteworthy projects -->
    <div class="relative">
      <h3 class="text-lg font-semibold mb-6 text-text-secondary tracking-tight">
        Other noteworthy projects
      </h3>
      <div class="grid sm:grid-cols-2 gap-4">
        {other.map(project => (
          <a
            href={project.live || project.github}
            target="_blank"
            rel="noopener noreferrer"
            class="card-glow spotlight-card group p-5 rounded-xl border border-border-subtle/30 bg-bg-secondary/15 hover:bg-bg-secondary/35 transition-all duration-300 flex flex-col"
          >
            <div class="flex items-start justify-between gap-2 mb-2.5">
              <h4 class="text-sm font-semibold text-text-primary group-hover:text-accent-light transition-colors leading-snug">
                {project.title}
              </h4>
              <div class="flex items-center gap-2.5 shrink-0 mt-0.5">
                {project.github && (
                  <svg class="w-3.5 h-3.5 text-text-muted/40 group-hover:text-text-muted/70 transition-colors" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                  </svg>
                )}
                {project.live && (
                  <span class="w-1.5 h-1.5 rounded-full bg-green/60"></span>
                )}
              </div>
            </div>
            <p class="text-xs text-text-muted leading-relaxed line-clamp-2 mb-auto pb-3">
              {project.description}
            </p>
            <div class="pt-3 border-t border-border-subtle/15">
              <span class="text-[10px] font-mono text-text-muted/50 leading-relaxed">
                {project.tech.join(' · ')}
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>

  </div>
</section>
