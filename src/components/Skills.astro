---
// Map skill names to their svgl icon filenames (dark variants for dark bg)
const iconMap: Record<string, string> = {
  "TypeScript": "typescript",
  "JavaScript": "javascript",
  "Python": "python",
  "Go": "go",
  "HTML/CSS": "html5",
  "React 19": "react",
  "Next.js 16": "nextjs",
  "Astro": "astro",
  "Tailwind CSS v4": "tailwindcss",
  "TanStack Query": "tanstack",
  "Remotion": "remotion",
  "Node.js": "nodejs",
  "Hono": "hono",
  "Convex": "convex",
  "Drizzle ORM": "drizzle",
  "PostgreSQL": "postgresql",
  "Redis": "redis",
  "tRPC": "trpc",
  "Prisma": "prisma",
  "AWS": "aws",
  "Cloudflare Workers": "cloudflare",
  "Cloudflare D1": "cloudflare",
  "Vercel": "vercel",
  "Docker": "docker",
  "Turborepo": "turborepo",
  "GitHub Actions": "github",
  "Terraform": "terraform",
  "Kubernetes": "kubernetes",
  "Vercel AI SDK": "vercel",
  "PostHog A/B Testing": "posthog",
  "OpenAI": "openai",
  "Replicate": "replicate",
  "MongoDB": "mongodb",
  "Solana": "solana",
  "Ethereum": "ethereum",
  "Auth.js": "authjs",
  "PyTorch": "pytorch",
  "scikit-learn": "scikitlearn",
};

const categories = [
  {
    title: "Languages",
    icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>`,
    skills: ["TypeScript", "JavaScript", "Python", "Go", "SQL", "HTML/CSS"],
    span: 5,
  },
  {
    title: "Frontend",
    icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
    skills: ["React 19", "Next.js 16", "Astro", "Tailwind CSS v4", "TanStack Query", "Jotai", "Remotion"],
    span: 7,
  },
  {
    title: "Backend & Data",
    icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2"/></svg>`,
    skills: ["Node.js", "Hono", "Convex", "Drizzle ORM", "PostgreSQL", "Redis", "BullMQ", "Inngest", "tRPC", "Prisma", "MongoDB", "Cloudflare D1"],
    span: 7,
  },
  {
    title: "Cloud & Infra",
    icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z"/></svg>`,
    skills: ["AWS", "Cloudflare Workers", "Vercel", "Docker", "Kubernetes", "Terraform", "Turborepo", "GitHub Actions"],
    span: 5,
  },
  {
    title: "AI & ML",
    icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
    skills: ["PyTorch", "scikit-learn", "Vercel AI SDK", "LangChain", "Workers AI", "OpenAI", "Replicate", "fal.ai", "RAG", "Embeddings", "PostHog A/B Testing"],
    span: 5,
  },
  {
    title: "Web3 & Auth",
    icon: `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>`,
    skills: ["Solana", "Ethereum", "BIP-39/44", "Better Auth", "Auth.js", "OAuth (Meta, TikTok, YouTube)"],
    span: 7,
  },
];
---

<section id="skills" class="relative py-32 px-6">
  <!-- Background accent -->
  <div class="absolute inset-0 bg-bg-secondary/30"></div>

  <div class="max-w-6xl mx-auto relative z-10">
    <span class="section-label">Skills</span>
    <h2 class="text-3xl sm:text-4xl font-bold tracking-tight mb-4">
      Tech stack
    </h2>
    <p class="text-text-secondary mb-12 max-w-xl">
      Battle-tested technologies I use in production every day.
    </p>

    <!-- Zig-zag bento grid: 5/7 → 7/5 → 5/7 column rhythm -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
      {categories.map(category => (
        <div class:list={[
          "p-6 rounded-2xl border border-border-subtle bg-bg-primary/50 hover:border-border-accent transition-all duration-300 group",
          category.span === 5 ? "md:col-span-5" : "md:col-span-7"
        ]}>
          <div class="flex items-center gap-3 mb-5">
            <div class="w-8 h-8 rounded-lg bg-accent/10 border border-accent/20 flex items-center justify-center text-accent-light">
              <Fragment set:html={category.icon} />
            </div>
            <h3 class="text-sm font-semibold text-text-primary">{category.title}</h3>
          </div>
          <div class="flex flex-wrap gap-2 skill-badge-group">
            {category.skills.map((skill, idx) => (
              <span class="tech-badge" style={`--badge-i:${idx}`}>
                {iconMap[skill] && (
                  <img
                    src={`/icons/${iconMap[skill]}.svg`}
                    alt=""
                    width="14"
                    height="14"
                    class="tech-badge-icon"
                    loading="lazy"
                  />
                )}
                {skill}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // Stagger-reveal badges when their parent card enters the viewport
  const groups = document.querySelectorAll('.skill-badge-group');
  const groupObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const badges = entry.target.querySelectorAll<HTMLElement>('.tech-badge');
          badges.forEach((badge, i) => {
            badge.style.opacity = '0';
            badge.style.animationDelay = `${i * 45}ms`;
            badge.classList.add('badge-animate');
            badge.style.opacity = '';
          });
          groupObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.2 }
  );
  groups.forEach((g) => groupObserver.observe(g));
</script>
